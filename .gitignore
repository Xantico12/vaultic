# Binaries
/vaultic
/vaultic-server

# Data
vaultic.wal

# Test artifacts
*.test
coverage.out

# Go module proxy / cache (rare but happens)
vendor/

# OS junk
.DS_Store

# Editor
.vscode/
.idea/
.prettierrc
.prettierrc.*
.prettierignore

# TLS material — generated on first run, regenerated if missing
/vaultic.cert
/vaultic.key

# Token registry — contains only hashes but still per-vault state, never commit
/vaultic.tokens

# Audit log — per-vault state
/vaultic.audit
